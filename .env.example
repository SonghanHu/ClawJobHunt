# Official image
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:latest

# Gateway runtime
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_GATEWAY_TOKEN=replace-with-a-long-random-token

# Task progress dashboard (read-only)
TASK_PROGRESS_PORT=3080

# Host persistence (use absolute paths)
OPENCLAW_CONFIG_DIR=/absolute/path/to/openclaw/.openclaw-data
OPENCLAW_WORKSPACE_DIR=/absolute/path/to/openclaw/.openclaw-data/workspace

# Model providers (fill in the ones you use)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_API_KEY=
MINIMAX_API_KEY=
BRAVE_API_KEY=

# Gmail (gogcli) — see README.md for OAuth setup
GMAIL_API_KEY=
GOG_KEYRING_PASSWORD=openclaw
